---
import Navbar from "../components/Navbar.astro";
import Footer from '../components/footer.astro';

const { title = "FODI GROUP" } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      /* Define your brand fonts here if you have the files */
      @font-face {
        font-family: 'CenturyGothic';
        src: url('/fonts/CenturyGothic.woff2') format('woff2');
      }
    </style>
  </head>
  <body class="bg-white">
    
    <main>
      <slot /> </main>

    <Footer />
  </body>
</html>