---
import Layout from "../../../layouts/Layout.astro";
import brochures from "../../../assets/brochures.avif";

const service={ title: "Impression Offset" };
const heroStyle = `background-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(38,38,38,0.8), rgba(38,38,38,1)), url('${brochures.src}');`;
---


<!DOCTYPE html>
  <html lang="en">
      <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
         <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <title>FODI GROUP</title>
      </head>
      <Layout>
        
<section class="py-16 px-4">
  <div class="container mx-auto">
    <div class="grid place-items-center text-center bg-cover bg-no-repeat mb-10" style={heroStyle}>
    <div class="text-center mb-16">
        <h1 class="text-3xl md:text-5xl font-black text-[#1B80BE] font-century mb-4">IMPRESSION OFFSET</h1>
        <p class="max-w-2xl mx-auto text-lg text-[#767171] md:text-xl mb-10 leading-relaxed">Solution idéale pour les impressions en grande quantité avec une qualité professionnelle irréprochable.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
          <a href="/contact" class="px-8 py-4 bg-emerald-600 text-white font-bold rounded-xl shadow-lg hover:bg-blue-800 hover:-translate-y-1 transition-all duration-300">Obtenir un Devis</a>
          <a href={`/projects?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="px-8 py-4 border-2 border-blue-900 rounded-xl hover:bg-blue-50 duration-300 inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">Nos Projets</a>
    </div>
       <p class="text-xl md:text-2xl mx-12 mb-16">Impression offset est une technique d’impression industrielle adaptée aux grands tirages. Elle garantit une qualité constante, des couleurs précises et un coût optimisé pour les volumes importants.t</p>
      <div class="text-center mb-10">
        <h2 class="text-[#1B80BE] font-medium text-2xl md:text-3xl font-century">Advantages de ce services</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mx-12 text-center mb-16">
        <div class="group bg-gray-50 shadow-lg p-6 rounded-2xl hover:shadow-2xl border border-[#47AD43] transition-allduration-300">
            Haute qualité d’impression
        </div>
        <div class="group bg-gray-50 shadow-lg p-6 rounded-2xl hover:shadow-2xl border border-[#47AD43] transition-allduration-300">
            Coût réduit pour grands volumes
        </div>
        <div class="group bg-gray-50 shadow-lg p-6 rounded-2xl hover:shadow-2xl border border-[#47AD43] transition-allduration-300">
           Fidélité des couleurs
        </div>
        <div class="bg-gray-50 shadow-lg p-6 rounded-2xl hover:shadow-2xl border border-[#47AD43] transition-allduration-300">
            Production rapide
        </div>
    </div>
        <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-[#1B80BE] mb-4 font-century">Nos Produits en Offset</h2>
        <div class="grid grid-cols-4">
        <ol>
            <li>Brochures</li>
            <li>Magazines</li>
            <li>Catalogues</li>
            <li>Flyers</li>
            <li>Dépliants</li>
            <li>Affiches</li>
        </ol>
        </div>
      </div>
      </div>
</div>
</section>
</body>
    </Layout>
</html>
