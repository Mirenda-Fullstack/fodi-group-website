---
import Layout from "../../layouts/Layout.astro";

const services = [
  {
    title: "VENTE DE BOIS DEPITE",
    img: "images/OIP (4).webp",
    desc: "Large choix d'essences locales et importées pour tous  vos projets de construction",
    subservices: ["Bois Rouge", "Bois Blanc", "Essences Tropicales"]
  },
  {
    title: "TRANSFORMATION DE BOIS",
    img: "images/OIP (3).webp",
    desc: "Atelier de menuiserie moderne pour la fabrication de meubles et d'éléments de finition.",
    subservices: ["Portes", "Fenêtres", "Mobilier", "Plinthes"]
  },
  {
    title: "SCIAGE SUR MESSURE",
    img: "images/OIP (7).webp",
    desc: "Débit de bois de construction selon vos dimensions précises pour charpentes et coffrages",
    subservices: ["Poutres", "Chevrons", "Planches", "Lattes"]
  },
  {
   title: "TRAITEMENT DU BOIS",
    img: "images/Traitement de bois.webp",
    desc: "Protection contre les termites, l'humidité et les champignons pour une longévité accrue.",
    subservices: ["Autoclave", "Fongicide", "Insecticide", "Vernis"]
  }
];

---

 <section class="py-20 px-4 bg-gray-50">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-[#968E3C] mb-4 font-century">Bois & Scierie</h2>
        <p class="font-medium max-w-2xl mx-auto text-[#986E3C]">Exploitation de Bois</p>
        <div class="w-24 h-1.5 bg-[#767171] mx-auto mt-6 rounded-full"></div>
      </div>
  
  <!--Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-10">
        {services.map((service) => (
          <div class="group bg-white rounded-2xl shadow-sm border-b-4 border-b-[#986E3C] border-gray-100  transition-all duration-300 flex flex-col overflow-hidden hover:shadow-xl">
            <div class="h-94 overflow-hidden relative">
             <img src={service.img} alt={service.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-8 flex flex-col grow">
            <h3 class="text-xl font-bold text-[#767171] mb-3 font-century">{service.title}</h3>
            <p class="text-[#767171] mb-6 leading-relaxed text-sm">{service.desc}</p>
  
          <div class="mb-8">
            <p class="text-[10px] font-bold uppercase tracking-tighter text-[#1B80BE] mb-3">Nos Solutions: </p>
            <div class="flex flex-wrap gap-2">
              {service.subservices.map((sub) => (
                 <span class="px-3 py-1 bg-orange-50 text-[#986E3C] text-[10px] font-bold rounded-md border border-orange-100">
                  {sub} 
                 </span>
                ))}
            </div>
          </div>
  
         <div class="mt-auto pt-6 border-t border-gray-100 flex items-center justify-between">
           <a href={`/bois?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">
           En savoir plus <span class="ml-2">→</span></a>
          <a href={`/projects?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">
            Voir nos réalisations <span class="ml-2">→</span>
          </a>
        </div>
        </div>
      </div>
        ))}
        </div>
        </div>
  </section>