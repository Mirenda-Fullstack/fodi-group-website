---
const services = [
  {
    title: "TRANSPORT DE MARCHANDISES",
    img: "images/transport.avif",
    desc: "Solutions de fret routier sécuriséés pour lùqchine,ent de vos produits, de bois aux materiaux de construction",
    subservices: ["Fret Natinal", "Zone CE?QC", "Suivi en Temp Réel", "Securité Garanti"]
  },
  {
    title: "IMPORT / EXPORT",
    img: "images/transport.webp", 
    desc: "Facilitateur de commerce international. Nous gérons le transit et les formalités pour vos échanges mondiaux.",
    subservices: ["Transit Douanier", "Conseil Import", "Logistique Maritime", "Gestion de Fret"]
  },
  {
    title: "LOGISTIQUE & STOCKAGE",
    img: "images/logistique.avif", 
    desc: "Entreposage moderne et gestion de stock stratégique pour optimiser votre chaîne d'approvisionnement.",
    subservices: ["Entreposage", "Manutention", "Gestion de Stock", "Distribution"]
  },
  {
    title: "LIVRAISON URBAINE",
    img: "images/livraison.avif", 
    desc: "Service agile pour vos livraisons express en ville. Idéal pour les colis urgents, le courrier et le dernier kilomètre.",
    subservices: ["Livraison Express", "Coursiers Dédiés", "Dernier Kilomètre", "Suivi Mobile"]
  },
];

---
<section class="py-20 px-4 bg-gray-50">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-[#1B80BE] mb-4 font-century">Transport & Logistique</h2>
        <p class="text-[#767171] font-medium max-w-2xl mx-auto">Des espaces de vie et d'évnements conçu pour votre excellence</p>
        <div class="w-24 h-1.5 bg-[#47AD43] mx-auto mt-6 rounded-full"></div>
      </div>
  
  <!--Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {services.map((service) => (
          <div class="group bg-white rounded-2xl shadow-sm border-b-4 border-b-[#986E3C] border-gray-100  transition-all duration-300 flex flex-col overflow-hidden hover:shadow-xl">
            <div class="h-94 overflow-hidden relative">
             <img 
               src={service.img}
               alt={service.title}
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-8 flex flex-col grow">
            <h3 class="text-2xl font-bold text-[#767171] mb-3 font-century">{service.title}</h3>
            <p class="text-[#767171] mb-6 leading-relaxed text-sm">{service.desc}</p>
  
          <div class="mb-8">
            <p class="text-[10px] font-bold uppercase tracking-tighter text-[#1B80BE] mb-3">Nos Solutions: </p>
            <div class="flex flex-wrap gap-2">
              {service.subservices.map((sub) => (
                 <span class="px-3 py-1 bg-emerald-50 text-[#767171] text-xs font-semibold rounded-md border border-gray-100">
                  {sub} 
                 </span>
                ))}
            </div>
          </div>
  
       <div class="mt-auto pt-6 border-t border-gray-100 flex items-center justify-between">
           <a href={`/transport?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">
           En savoir plus <span class="ml-2">→</span></a>
          <a href={`/projects?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">
            Voir nos réalisations <span class="ml-2">→</span>
          </a>
        </div>
        </div>
      </div>
        ))}
        </div>
        </div>
  </section>