---
const services = [
  {
    title: "CONSTRUCTION",
    img: "images/construction.jpeg",
    desc: "Réalisation de bâtiments résidentiels, commerciaux et industriels avec des standards de qualité élevés.",
    subservices: ["Maisons", "Immeubles", "Entrepôts", "Bureaux"]
  },
  {
    title: "TRAVAUX PUBLICS",
    img: "images/travaux-publics.jpeg",
    desc: "Infrastructures essentielles pour le développement urbain et rural.",
    subservices: ["Routes", "Ponts", "Canalisations", "Ouvrages d’art"]
  },
  {
    title: "ÉQUIPEMENTS & MATÉRIAUX",
    img: "images/materiaux.jpeg",
    desc: "Fourniture de matériaux et équipements fiables pour vos chantiers.",
    subservices: ["Ciment", "Acier", "Bois", "Machines de chantier"]
  },
  {
    title: "MAINTENANCE & RÉNOVATION",
    img: "images/renovation.jpeg",
    desc: "Services de rénovation et d’entretien pour prolonger la durée de vie de vos infrastructures.",
    subservices: ["Rénovation intérieure", "Réhabilitation", "Entretien préventif", "Modernisation"]
  }
];

---

<section class="py-20 px-4 bg-50">
   <div class="container mx-auto max-w-6xl">
    <div class="text-center mb-16">
     <h2 class="text-[#1B80BE] font-black text-3xl md:text-5xl mb-4 font-century">Bâtiment & Travaux Publics</h2>
     <p class="text-[#767171] max-w-2xl mx-auto font-medium">Solutions complètes pour la construction, les infrastructures et la rénovation, avec des matériaux fiables et un savoir-faire reconnu</p>
     <div class="w-24 h-1.5 bg-[#47AD43] mt-6 rounded-full mx-auto"></div>
    </div>

      <!--Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {services.map((service) => (
          <div class="group bg-white rounded-2xl shadow-sm border-b-4 border-b-[#986E3C] border-gray-100  transition-all duration-300 flex flex-col overflow-hidden hover:shadow-xl">
            <div class="h-94 overflow-hidden relative">
             <img 
               src={service.img}
               alt={service.title}
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-8 flex flex-col grow">
            <h3 class="text-2xl font-bold text-[#767171] mb-3 font-century">{service.title}</h3>
            <p class="text-[#767171] mb-6 leading-relaxed text-sm">{service.desc}</p>
  
          <div class="mb-8">
            <p class="text-[10px] font-bold uppercase tracking-tighter text-[#1B80BE] mb-3">Nos Solutions: </p>
            <div class="flex flex-wrap gap-2">
              {service.subservices.map((sub) => (
                 <span class="px-3 py-1 bg-emerald-50 text-[#767171] text-xs font-semibold rounded-md border border-gray-100">
                  {sub} 
                 </span>
                ))}
            </div>
          </div>
  
        <div class="mt-auto pt-6 border-t border-gray-100 flex items-center justify-between">
          <a href={`/projects?filter=${service.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center text-[#47AD43] font-bold hover:translate-x-1 transition-transform">
            Voir nos réalisations <span class="ml-2">→</span>
          </a>
        </div>
        </div>
      </div>
        ))}
        </div>
        </div>
  </section>